{
  "ConnectionStrings": {
    "SqlServerConnection": "${DB_CONNECTION_STRING}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Environment": {
    "Debug": "${ENVIRONMENT_DEBUG}",
    "Services": "${ENVIRONMENT_SERVICES_DEV}"
  },
  "Telegram": {
    "id": "${TELEGRAM_BOT_TOKEN}"
  },
  "AWS": {
    "Profile": "${AWS_PROFILE}",
    "AccessKey": "${AWS_ACCESS_KEY}",
    "SecretKey": "${AWS_SECRET_KEY}",
    "Region": "${AWS_REGION}"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "${JWT_ISSUER}"
  },
  "PlatrumMetricsSettings": {
    "PlatrumApiKey": "${PLATRUM_API_KEY}",
    "PlatrumApiUrl": "${PLATRUM_API_URL}",
    "ClientErrorsMetricId": "${PLATRUM_CLIENT_ERRORS_METRIC_ID}",
    "ServerErrorsMetricId": "${PLATRUM_SERVER_ERRORS_METRIC_ID}",
    "PlatrumUserId": "${PLATRUM_USER_ID}"
  },
  "DomainUrl": "${DOMAIN_URL_LOCAL}",
  "ApplicationDomainUrl": "${APPLICATION_DOMAIN_URL_LOCAL}"
}